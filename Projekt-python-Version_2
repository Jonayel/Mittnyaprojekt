
import random
def skapa_hemligt_tal():
    return random.randint(1, 100)

def hamta_gissning():
    gissning = int(input("Gissa ett tal mellan 1 och 100: "))
    return gissning

def kontrollera_gissning(gissning, hemligt_tal):
    if gissning < hemligt_tal:
        print("För lågt!")
        return False
    elif gissning > hemligt_tal:
        print("För högt!")
        return False
    else:
        print("Rätt!")
        return True

def spela():
    hemligt_tal = skapa_hemligt_tal()
    antal_forsok = 0

    while True:
        gissning = hamta_gissning()
        antal_forsok = antal_forsok + 1

        ratt = kontrollera_gissning(gissning, hemligt_tal)

        if ratt:
            print("Du klarade det på", antal_forsok, "försök.")
            break

spela()